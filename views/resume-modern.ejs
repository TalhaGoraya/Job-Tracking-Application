<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title><%= profile.role_label %> — <%= userInfo.full_name || 'Resume' %></title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 10.5pt; color: #1e293b; background: #fff; line-height: 1.5; }
  .page { max-width: 800px; margin: 0 auto; padding: 48px 52px; }
  header { border-bottom: 3px solid #4f46e5; padding-bottom: 16px; margin-bottom: 20px; }
  h1 { font-size: 22pt; font-weight: 800; color: #0f172a; letter-spacing: -0.5px; }
  .headline { font-size: 11pt; color: #4f46e5; font-weight: 600; margin: 4px 0 10px; }
  .contact { display: flex; flex-wrap: wrap; gap: 4px 16px; font-size: 9pt; color: #475569; }
  section { margin-bottom: 18px; }
  h2 { font-size: 10pt; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: #4f46e5; border-bottom: 1px solid #e0e7ff; padding-bottom: 4px; margin-bottom: 10px; }
  .summary { font-size: 10pt; color: #334155; line-height: 1.6; }
  .exp-item { margin-bottom: 12px; }
  .exp-header { display: flex; justify-content: space-between; align-items: baseline; }
  .exp-title { font-weight: 700; font-size: 10.5pt; }
  .exp-company { color: #475569; font-size: 9.5pt; }
  .exp-dates { font-size: 9pt; color: #94a3b8; white-space: nowrap; }
  ul { padding-left: 16px; margin-top: 4px; }
  li { font-size: 9.5pt; margin-bottom: 2px; }
  .skills-wrap { display: flex; flex-wrap: wrap; gap: 6px; }
  .skill-tag { background: #eef2ff; color: #4f46e5; border-radius: 4px; padding: 2px 9px; font-size: 9pt; font-weight: 600; }
  .edu-item { display: flex; justify-content: space-between; }
  .disclaimer { margin-top: 24px; padding-top: 12px; border-top: 1px solid #e2e8f0; font-size: 8pt; color: #94a3b8; text-align: center; }
  .print-btn { position: fixed; top: 16px; right: 16px; background: #4f46e5; color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-size: 13px; font-weight: 600; cursor: pointer; box-shadow: 0 2px 8px rgba(79,70,229,.3); }
  @media print {
    .print-btn { display: none; }
    body { font-size: 10pt; }
    .page { padding: 20px 24px; max-width: 100%; }
  }
</style>
</head>
<body>
<button class="print-btn" onclick="window.print()">⬇ Download PDF</button>
<div class="page">
  <header>
    <h1><%= userInfo.full_name || 'Your Name' %></h1>
    <div class="headline"><%= profile.role_label %></div>
    <div class="contact">
      <% if (userInfo.location) { %><span>📍 <%= userInfo.location %></span><% } %>
      <% if (userInfo.phone) { %><span>📞 <%= userInfo.phone %></span><% } %>
      <% if (userInfo.linkedin) { %><span>🔗 <%= userInfo.linkedin %></span><% } %>
    </div>
  </header>

  <% if (data.summary) { %>
  <section>
    <h2>Summary</h2>
    <p class="summary"><%= data.summary %></p>
  </section>
  <% } %>

  <% if (data.experience && data.experience.length) { %>
  <section>
    <h2>Experience</h2>
    <% data.experience.forEach(exp => { %>
    <div class="exp-item">
      <div class="exp-header">
        <div>
          <span class="exp-title"><%= exp.title %></span>
          <span class="exp-company"> · <%= exp.company %></span>
        </div>
        <span class="exp-dates"><%= exp.dates %></span>
      </div>
      <% if (exp.bullets && exp.bullets.length) { %>
      <ul><% exp.bullets.forEach(b => { %><li><%= b %></li><% }) %></ul>
      <% } %>
    </div>
    <% }) %>
  </section>
  <% } %>

  <% if (data.skills && data.skills.length) { %>
  <section>
    <h2>Skills</h2>
    <div class="skills-wrap">
      <% data.skills.forEach(s => { %><span class="skill-tag"><%= s %></span><% }) %>
    </div>
  </section>
  <% } %>

  <% if (data.education && data.education.length) { %>
  <section>
    <h2>Education</h2>
    <% data.education.forEach(ed => { %>
    <div class="edu-item">
      <span><strong><%= ed.degree %></strong> · <%= ed.school %></span>
      <span style="color:#94a3b8;font-size:9pt;"><%= ed.year %></span>
    </div>
    <% }) %>
  </section>
  <% } %>

  <div class="disclaimer">⚠️ This resume was AI-assisted. Review before use.</div>
</div>
</body>
</html>
